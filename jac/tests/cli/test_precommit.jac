"""Tests for `jac precommit` -- the repo's pre-commit path (clean break from
the python pre-commit framework).

Two properties are pinned here:

1. `--staged --verify` gates the STAGED BLOBS, not the working tree. A hook
   that verifies worktree files lets unformatted staged content into the
   commit whenever the worktree copy has since been fixed (and conversely
   rejects clean staged content over a dirty worktree).

2. `--install` migrates cleanly: a hook generated by the python pre-commit
   framework is replaced automatically (backed up alongside), any other
   foreign hook requires `--force`, and force always backs up.
"""

import os;
import shutil;
import subprocess;
import tempfile;
import from pathlib { Path }

import from jaclang.cli.commands.analysis { precommit }

glob UNFORMATTED = "def f(x:int)->int{return x+1;}\n",
     FORMATTED = "def f(x: int) -> int {\n    return x + 1;\n}\n";

"""Create a temp git repo with a jac.toml; return its path."""
def make_repo -> str {
    repo = tempfile.mkdtemp(prefix="jac-precommit-test-");
    subprocess.run(["git", "init", "-q", repo], check=True);
    (Path(repo) / "jac.toml").write_text('[project]\nname = "pctest"\n');
    return repo;
}

test "staged verify gates the staged blob not the worktree" {
    repo = make_repo();
    old = os.getcwd();
    os.chdir(repo);
    try {
        f = Path(repo) / "a.jac";
        # Stage UNFORMATTED content, then fix only the worktree copy: the
        # bytes about to be committed are still unformatted, so the gate
        # must fail even though the worktree file is clean.
        f.write_text(UNFORMATTED);
        subprocess.run(["git", "add", "a.jac"], check=True, cwd=repo);
        f.write_text(FORMATTED);
        ret = precommit(staged=True, verify=True);
    } finally {
        os.chdir(old);
        shutil.rmtree(repo, ignore_errors=True);
    }
    assert ret != 0 , "staged blob is unformatted -- verify must fail even though the "
    "worktree copy is formatted (the commit would contain the bad bytes)";
}

test "staged verify passes clean staged blob over dirty worktree" {
    repo = make_repo();
    old = os.getcwd();
    os.chdir(repo);
    try {
        f = Path(repo) / "a.jac";
        # Stage FORMATTED content, then dirty only the worktree copy: the
        # bytes about to be committed are clean, so the gate must pass.
        f.write_text(FORMATTED);
        subprocess.run(["git", "add", "a.jac"], check=True, cwd=repo);
        f.write_text(UNFORMATTED);
        ret = precommit(staged=True, verify=True);
    } finally {
        os.chdir(old);
        shutil.rmtree(repo, ignore_errors=True);
    }
    assert ret == 0 , "staged blob is formatted -- verify must pass regardless of "
    "unstaged worktree edits (partial-staging workflow)";
}

test "install replaces a pre-commit framework hook with backup" {
    repo = make_repo();
    old = os.getcwd();
    os.chdir(repo);
    try {
        hook = Path(repo) / ".git" / "hooks" / "pre-commit";
        hook.parent.mkdir(parents=True, exist_ok=True);
        hook.write_text(
            "#!/usr/bin/env bash\n"
            "# File generated by pre-commit: https://pre-commit.com\n"
            "exec pre-commit hook-impl\n"
        );
        ret = precommit(install=True);
        hook_text = hook.read_text();
        backed_up = (hook.parent / "pre-commit.bak").exists();
    } finally {
        os.chdir(old);
        shutil.rmtree(repo, ignore_errors=True);
    }
    assert ret == 0 , "installing over a python pre-commit framework hook must succeed "
    "(that is the migration path)";
    assert "jac precommit --staged --verify" in hook_text , f"hook must now run jac precommit, got:\n{hook_text}";
    assert backed_up , "the framework hook must be preserved as pre-commit.bak";
}

test "install refuses a foreign hook unless forced" {
    repo = make_repo();
    old = os.getcwd();
    os.chdir(repo);
    try {
        hook = Path(repo) / ".git" / "hooks" / "pre-commit";
        hook.parent.mkdir(parents=True, exist_ok=True);
        hook.write_text("#!/bin/sh\n./my_custom_checks.sh\n");
        refused = precommit(install=True);
        forced = precommit(install=True, force=True);
        hook_text = hook.read_text();
        backed_up = (hook.parent / "pre-commit.bak").exists();
    } finally {
        os.chdir(old);
        shutil.rmtree(repo, ignore_errors=True);
    }
    assert refused != 0 , "a hand-written foreign hook must not be silently replaced";
    assert forced == 0 , "--force must replace it";
    assert "jac precommit --staged --verify" in hook_text , f"hook must now run jac precommit, got:\n{hook_text}";
    assert backed_up , "--force must back the foreign hook up as pre-commit.bak";
}

test "precommit typecheck knob gates the check step" {
    # A formatted file with a TYPE error: with [precommit] typecheck = false
    # the gate passes (format-only commits while a codebase is not yet
    # check-clean); with the default it fails.
    bad = "def f(x: int) -> str {\n    return x;\n}\n";
    repo = make_repo();
    old = os.getcwd();
    os.chdir(repo);
    try {
        import from jaclang.project { config as config_mod }
        f = Path(repo) / "a.jac";
        f.write_text(bad);
        subprocess.run(["git", "add", "a.jac"], check=True, cwd=repo);
        # The config singleton may hold whatever repo the suite ran from;
        # reset around each call so precommit discovers THIS repo's toml.
        config_mod._config = None;
        with_check = precommit(staged=True, verify=True);
        (Path(repo) / "jac.toml").write_text(
            '[project]\nname = "pctest"\n\n[precommit]\ntypecheck = false\n'
        );
        config_mod._config = None;
        without_check = precommit(staged=True, verify=True);
        config_mod._config = None;
    } finally {
        os.chdir(old);
        shutil.rmtree(repo, ignore_errors=True);
    }
    assert with_check != 0 , "with typecheck on (default), a staged type error must fail the gate";
    assert without_check == 0 , "with [precommit] typecheck = false, only formatting gates the commit";
}
