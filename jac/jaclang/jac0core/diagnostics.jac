enum Severity { ERROR = "error", WARNING = "warning", NOTE = "note", HELP = "help" }

enum Category {
    SYNTAX = "syntax",
    TYPE = "type",
    SEMANTIC = "semantic",
    LINT = "lint",
    IMPORT = "import",
    CODEGEN = "codegen",
    RUNTIME = "runtime",
    ICE = "ice"
}

obj DiagnosticInfo {
    has code: str,
        severity: Severity,
        category: Category,
        message_template: str,
        help_text: str | None = None,
        url_slug: str | None = None,
        blocks_codegen: bool = False;

    def format_message(**kwargs: object) -> str {
        try {
            return self.message_template.format(**kwargs);
        } except KeyError as e {
            return f"{self.message_template} (missing key: {e})";
        }
    }
}

glob DIAGNOSTICS: dict[str, DiagnosticInfo] = {};

def _reg(
    code: str,
    severity: Severity,
    category: Category,
    template: str,
    help_text: str | None = None,
    blocks_codegen: bool = False
) -> DiagnosticInfo {
    info = DiagnosticInfo(
        code=code,
        severity=severity,
        category=category,
        message_template=template,
        help_text=help_text,
        url_slug=code.lower(),
        blocks_codegen=blocks_codegen
    );
    DIAGNOSTICS[code] = info;
    return info;
}

def _err(
    code: str,
    cat: Category,
    tmpl: str,
    help: str | None = None,
    blocks_codegen: bool = False
) -> DiagnosticInfo {
    return _reg(code, Severity.ERROR, cat, tmpl, help, blocks_codegen);
}

def _warn(
    code: str, cat: Category, tmpl: str, help: str | None = None
) -> DiagnosticInfo {
    return _reg(code, Severity.WARNING, cat, tmpl, help);
}

