# ruff: noqa: N801, N802, N803, N815, N816
"""ECMAScript / browser global stubs for Jac client code.

Client code (`.cl.jac` files and `cl { ... }` blocks) compiles to
JavaScript and runs in a browser, so it has access to the ECMAScript
standard built-in objects (Date, Math, JSON, Promise, ...) and the
browser host globals (console, window, document, fetch, ...). None of
these exist in the Python server runtime, so unlike dom_types.pyi these
names are NOT merged into the global builtins: the TypeEvaluator resolves
them through a client-context-gated lookup (mirroring how na_builtins.pyi
is gated to native context), so they stay invisible to server `.jac` code
where referencing them would be a genuine error.

Names use the JS spelling (camelCase, capitalized constructors) to match
the runtime API surface -- this is intentional, not a Python naming
violation. Dynamic returns are typed `object` (never `Any`) to match the
convention in dom_types.pyi. DOM element/event types (HTMLElement,
ChangeEvent, ...) and the Web Storage globals (localStorage,
sessionStorage) live in dom_types.pyi; this file is disjoint from it.
"""

from collections.abc import Callable, Generator
from typing import TYPE_CHECKING, Generic, TypeVar

if TYPE_CHECKING:
    # HTMLElement lives in dom_types.pyi, whose names the TypeEvaluator merges
    # into builtins, so `_Document`'s element members below resolve it
    # ambiently at check time. This guarded import is for static analysers
    # (e.g. Pylance) only -- it is never executed by the stub loader.
    from dom_types import HTMLElement

_T = TypeVar("_T")

__all__ = [
    # Standard built-in objects
    "Date",
    "Math",
    "JSON",
    "Promise",
    "RegExp",
    "Number",
    "String",
    "Boolean",
    "Array",
    "Object",
    "BigInt",
    # Binary / typed data (wasm interop)
    "ArrayBuffer",
    "Uint8Array",
    "Int32Array",
    "Uint32Array",
    "Float32Array",
    "Float64Array",
    "DataView",
    "WebAssembly",
    # WHATWG fetch / streams / encoding
    "Headers",
    "Response",
    "ReadableStream",
    "ReadableStreamDefaultReader",
    "ReadableStreamReadResult",
    "TextDecoder",
    "TextEncoder",
    # Host globals
    "console",
    "window",
    "document",
    "navigator",
    "location",
    "history",
    "screen",
    # Global functions
    "parseInt",
    "parseFloat",
    "isNaN",
    "isFinite",
    "encodeURIComponent",
    "decodeURIComponent",
    "encodeURI",
    "decodeURI",
    "setTimeout",
    "setInterval",
    "clearTimeout",
    "clearInterval",
    "requestAnimationFrame",
    "cancelAnimationFrame",
    "queueMicrotask",
    "structuredClone",
    "fetch",
    "alert",
    "confirm",
    "prompt",
]

