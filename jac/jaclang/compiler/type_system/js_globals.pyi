# ── WHATWG fetch / streams / encoding ──────────────────────────────────
# The host-object surface cl code realistically touches (issue #7114):
# `fetch` -> `Response`, the byte-stream reader loop behind it, and the
# text codecs. Scope rule: model the HOST environment only -- JS method
# surfaces are never grafted onto Jac primitives (that is the portability
# lint's territory, W6002). Dynamic payloads (`json()`) stay `object`;
# callers re-type them at the boundary with an explicit `as` cast per the
# strict-gradual rule.

class ReadableStreamReadResult(Generic[_T]):
    """One `reader.read()` result: `{done, value}`. `value` is typed as the
    stream's chunk type unconditionally (the spec leaves it undefined once
    `done` is true; loops must check `done` before touching `value`)."""

    done: bool
    value: _T

class ReadableStreamDefaultReader(Generic[_T]):
    """The default reader of a `ReadableStream` (`stream.getReader()`)."""

    closed: Promise[None]
    def read(self) -> Promise[ReadableStreamReadResult[_T]]: ...
    def cancel(self, reason: object = ...) -> Promise[None]: ...
    def releaseLock(self) -> None: ...

class ReadableStream(Generic[_T]):
    """A WHATWG readable byte/object stream (e.g. `Response.body`)."""

    locked: bool
    def __init__(self, *args: object) -> None: ...
    def getReader(self, *args: object) -> ReadableStreamDefaultReader[_T]: ...
    def cancel(self, reason: object = ...) -> Promise[None]: ...
    def pipeThrough(
        self, transform: object, options: object = ...
    ) -> ReadableStream[object]: ...
    def pipeTo(self, destination: object, options: object = ...) -> Promise[None]: ...
    def tee(self) -> list[ReadableStream[_T]]: ...

class Headers:
    """The `fetch` Headers object (request/response header map)."""

    def __init__(self, init: object = ...) -> None: ...
    def get(self, name: str) -> str | None: ...
    def has(self, name: str) -> bool: ...
    def set(self, name: str, value: str) -> None: ...
    def append(self, name: str, value: str) -> None: ...
    def delete(self, name: str) -> None: ...
    def forEach(self, callback: object) -> None: ...
    def keys(self) -> object: ...
    def values(self) -> object: ...
    def entries(self) -> object: ...

class Response:
    """The `fetch` Response. `body` is typed non-nullable (it is null only
    for bodyless responses) so the ubiquitous `resp.body.getReader()` chain
    resolves -- the same pragmatic choice as `_Document.body`."""

    ok: bool
    status: float
    statusText: str
    url: str
    redirected: bool
    bodyUsed: bool
    headers: Headers
    body: ReadableStream[Uint8Array]
    def __init__(self, *args: object) -> None: ...
    def json(self) -> Promise[object]: ...
    def text(self) -> Promise[str]: ...
    def blob(self) -> Promise[object]: ...
    def arrayBuffer(self) -> Promise[ArrayBuffer]: ...
    def formData(self) -> Promise[object]: ...
    def clone(self) -> Response: ...

class TextDecoder:
    """Decodes binary chunks (e.g. `Uint8Array`) to text (`new(TextDecoder)`)."""

    encoding: str
    fatal: bool
    ignoreBOM: bool
    def __init__(self, label: str = ..., options: object = ...) -> None: ...
    def decode(self, input: object = ..., options: object = ...) -> str: ...

class TextEncoder:
    """Encodes text to UTF-8 bytes (`new(TextEncoder)`)."""

    encoding: str
    def __init__(self) -> None: ...
    def encode(self, input: str = ...) -> Uint8Array: ...
    def encodeInto(self, source: str, destination: Uint8Array) -> object: ...

