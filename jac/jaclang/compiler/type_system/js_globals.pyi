class Promise(Generic[_T]):
    """A pending value; the result of an async call or `new Promise(...)`."""

    def __init__(self, executor: Callable[..., object]) -> None: ...
    # `await p` on a Promise[T] must yield T. The evaluator unwraps
    # awaitables through `__await__`'s declared generator return type
    # (see TypeEvaluator._unwrap_awaitable_type), so declaring it here is
    # what makes `resp = await fetch(...)` produce a Response rather than
    # leaving the Promise wrapper on every awaited result.
    def __await__(self) -> Generator[object, object, _T]: ...
    def then(self, *args: object) -> Promise[object]: ...
    def catch(self, on_rejected: object) -> Promise[object]: ...
    def finally_(self, on_finally: object) -> Promise[_T]: ...
    @staticmethod
    def resolve(value: _T) -> Promise[_T]: ...
    @staticmethod
    def reject(reason: object) -> Promise[object]: ...
    @staticmethod
    def all(values: object) -> Promise[object]: ...
    @staticmethod
    def allSettled(values: object) -> Promise[object]: ...
    @staticmethod
    def race(values: object) -> Promise[object]: ...

