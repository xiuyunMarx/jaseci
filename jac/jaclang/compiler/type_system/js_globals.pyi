# JS `Number`/`String`/`Boolean`/`Array` are callable coercions that also
# carry static helpers. Model them as primitive subclasses (the same pattern
# as the fixed-width numeric types in jac_builtins.pyi) so `Number(x)` stays
# usable as the underlying primitive while `Number.isInteger(x)` resolves.

class Number(float):
    """The `Number` global (coercion call + static helpers)."""

    MAX_SAFE_INTEGER: float
    MIN_SAFE_INTEGER: float
    MAX_VALUE: float
    MIN_VALUE: float
    EPSILON: float
    POSITIVE_INFINITY: float
    NEGATIVE_INFINITY: float
    NaN: float
    @staticmethod
    def isInteger(value: object) -> bool: ...
    @staticmethod
    def isFinite(value: object) -> bool: ...
    @staticmethod
    def isNaN(value: object) -> bool: ...
    @staticmethod
    def isSafeInteger(value: object) -> bool: ...
    @staticmethod
    def parseFloat(value: str) -> float: ...
    @staticmethod
    def parseInt(value: str, radix: float = ...) -> float: ...

class String(str):
    """The `String` global (coercion call + static helpers)."""

    @staticmethod
    def fromCharCode(*codes: float) -> str: ...
    @staticmethod
    def fromCodePoint(*codes: float) -> str: ...

class Boolean(int):
    """The `Boolean` global (coercion call)."""

class Array(list[object]):
    """The `Array` global (constructor + static helpers)."""

    @staticmethod
    def isArray(value: object) -> bool: ...
    @staticmethod
    def of(*items: _T) -> list[_T]: ...
    @staticmethod
    def from_(iterable: object, *args: object) -> list[object]: ...

class Object:
    """The `Object` global (static helpers)."""

    @staticmethod
    def keys(obj: object) -> list[str]: ...
    @staticmethod
    def values(obj: object) -> list[object]: ...
    @staticmethod
    def entries(obj: object) -> list[object]: ...
    @staticmethod
    def assign(target: object, *sources: object) -> object: ...
    @staticmethod
    def freeze(obj: _T) -> _T: ...
    @staticmethod
    def create(proto: object, *args: object) -> object: ...
    @staticmethod
    def fromEntries(entries: object) -> object: ...

class BigInt(int):
    """The `BigInt` global: arbitrary-precision integer coercion + static
    helpers. Needed to pass/receive wasm `i64` values (Jac `int`) at the
    JS<->wasm boundary, where plain `number` is rejected."""

    def __init__(self, value: object = ...) -> None: ...
    @staticmethod
    def asUintN(bits: float, value: object) -> BigInt: ...
    @staticmethod
    def asIntN(bits: float, value: object) -> BigInt: ...

